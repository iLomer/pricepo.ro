# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Auth Configuration
# Enable Email/Password provider in Supabase Dashboard:
# https://supabase.com/dashboard/project/_/auth/providers
# 1. Go to Authentication > Providers > Email
# 2. Enable "Email" provider
# 3. Configure "Confirm email" as needed (disable for development)

# Google Analytics 4
# Get from: https://analytics.google.com/ > Admin > Data Streams > Measurement ID
# Only loads in production (NODE_ENV === 'production')
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Stripe
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# Stripe price IDs from Product Catalog
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
# Supabase service role key (for webhook operations that bypass RLS)
# Get from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_SERVICE_ROLE_KEY=

# Site URL (used for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=https://prevo.ro

# Brevo (transactional email sending)
# Get from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Cron Secret (optional)
# Used to authenticate cron job requests to /api/alerts/send
# Generate a random string and set in Vercel environment variables
CRON_SECRET=
